#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: brew check <formula> [...]

Run a strict online audit with autofix enabled.

Example:
  brew check chenrui333/tap/bun
EOF
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

brew audit --strict --git --online --fix "$@"
