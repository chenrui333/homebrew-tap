root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[{*.yml,*.yaml,*.json,*.json5,*.js,*.mjs,*.cjs,*.rb,*.toml}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[justfile]
indent_style = space
indent_size = 4

[{*.sh,*.bash}]
indent_style = tab
tab_width = 2

[Makefile]
indent_style = tab
