{
  extends: [
    'config:recommended',
    'docker:pinDigests',
    'helpers:pinGitHubActionDigests',
    ':configMigration',
    ':pinDevDependencies',
  ],
  commitMessagePrefix: 'chore(deps):',
  commitMessageSuffix: ' in {{packageFile}}',
  automerge: true,
  automergeType: 'pr',
  automergeStrategy: 'squash',
  baseBranchPatterns: [
    'main',
  ],
  platformAutomerge: true,
  labels: [
    'CI-syntax-only',
    'dependencies',
    'renovate',
  ],
  // Renovate's Homebrew manager currently only matches Formula/**. Ignore
  // formulae to avoid duplicating autobump-formula.yml, but leave Casks/**
  // visible in case Renovate adds native cask support later.
  ignorePaths: [
    'Formula/**',
  ],
  vulnerabilityAlerts: {
    enabled: true,
    labels: [
      'security',
    ],
  },
}
